# AWS Terraform Variables
# Copy this file to terraform.tfvars and fill in the values.
# NEVER commit terraform.tfvars to version control.

project_name = "bun-microservices"
environment  = "dev"
aws_region   = "us-east-1"

# Database
db_username = "dbadmin"
db_password = "CHANGE_ME_use_a_strong_password"

# Container
container_registry = "123456789012.dkr.ecr.us-east-1.amazonaws.com"
image_tag          = "latest"
service_replicas   = 1
service_cpu        = "512"
service_memory     = "1024"

# Sizing (adjust per environment)
# db_instance_class = "db.r6g.large"     # prod
# db_instance_class = "db.t4g.medium"    # dev/staging
# redis_node_type   = "cache.r6g.large"  # prod
# redis_node_type   = "cache.t4g.medium" # dev/staging
# msk_instance_type = "kafka.m5.large"   # prod
# msk_instance_type = "kafka.t3.small"   # dev/staging
