# ========================
# PostgreSQL
# ========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_MULTIPLE_DATABASES=auth_db,core_db

# ========================
# Redis
# ========================
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@localhost:6379

# ========================
# Auth Service
# ========================
AUTH_SERVICE_PORT=3002
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
AUTH_DATABASE_URL=postgresql://postgres:changeme@localhost:5432/auth_db?schema=public

# ========================
# Core Service
# ========================
CORE_SERVICE_PORT=3003
CORE_DATABASE_URL=postgresql://postgres:changeme@localhost:5432/core_db?schema=public

# ========================
# Existing Services
# ========================
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ========================
# Kafka
# ========================
KAFKA_BROKERS=localhost:9094

# ========================
# Observability
# ========================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ========================
# Grafana
# ========================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
