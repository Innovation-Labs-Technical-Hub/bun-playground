{
  "name": "auth-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "lint": "eslint src/",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio"
  },
  "dependencies": {
    "elysia": "^1.2",
    "@elysiajs/jwt": "^1.2",
    "@elysiajs/cors": "^1.2",
    "@casl/ability": "^6.7.2",
    "@prisma/client": "^6.5.0",
    "@bun-playground/shared-types": "workspace:*",
    "@bun-playground/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.5.0"
  }
}
